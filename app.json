{
  "expo": {
    "name": "Knitto",
    "slug": "knitto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ullogpinner",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F9FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sisuknitwear.knitto",
      "buildNumber": "11",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Knitto needs access to your photo library so you can add photos to your knitting projects and yarn stash. For example, you can attach a photo of a finished sweater or a skein of yarn.",
        "NSPhotoLibraryAddUsageDescription": "Knitto saves project and yarn photos to your photo library so you can access them later."
      }
    },
    "android": {
      "package": "com.sisuknitwear.knitto",
      "adaptiveIcon": {
        "backgroundColor": "#1A2340",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "569f135e-615c-4de4-85bd-94ee4a943eaa"
      }
    }
  }
}
